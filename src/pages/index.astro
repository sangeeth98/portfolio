---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
---

<Layout title="Sangeeth Kumar Vasudevan | Portfolio">
	<!-- Navbar Header -->
	<header class="navbar">
		<a href="#home" class="logo">
			<span class="logo-icon-wrapper" style="display: inline-flex; align-items: center; margin-right: 6px;">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent-color);"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.5 1 9.8a7 7 0 0 1-9 8.2z"/><path d="M9 22v-4"/></svg>
			</span>sangeeth
		</a>
		<nav class="nav-menu">
			<div class="nav-links">
				<a href="#home">Home</a>
				<a href="#about">About</a>
				<a href="#experience">Experience</a>
				<a href="#projects">Projects</a>
				<a href="#contact">Contact</a>
				
				<span class="nav-divider" aria-hidden="true"></span>
				
				<!-- Social / Contacts -->
				<a href="https://www.linkedin.com/in/sangeethkumarvm/" target="_blank" rel="noopener noreferrer" class="nav-icon-link" aria-label="LinkedIn">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.23 0H1.77C.8 0 0 .77 0 1.72v20.56C0 23.23.8 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.2 0 22.23 0zM7.12 20.45H3.56V9H7.12v11.45zM5.34 7.43c-1.14 0-2.06-.92-2.06-2.06 0-1.14.92-2.06 2.06-2.06 1.14 0 2.06.92 2.06 2.06 0 1.14-.92 2.06-2.06 2.06zm15.11 13.02h-3.56v-5.6c0-1.34-.03-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.7H9.33V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29z"/></svg>
				</a>
				<a href="https://github.com/sangeeth98" target="_blank" rel="noopener noreferrer" class="nav-icon-link" aria-label="GitHub">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
				</a>
				<a href="https://x.com/sangeethkumarvm" target="_blank" rel="noopener noreferrer" class="nav-icon-link" aria-label="Twitter">
					<svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
				</a>
				<button id="discord-nav-btn" class="nav-icon-link discord-nav-btn" data-copy-value="astro_legend" aria-label="Copy Discord handle">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
					<span class="discord-tooltip" id="discord-nav-tooltip">Copy Discord</span>
				</button>
				
				<span class="nav-divider" aria-hidden="true"></span>
				
				<button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle dark/light mode">
					<!-- Custom SVG theme icon -->
					<svg id="theme-svg" viewBox="0 0 24 24">
						<path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" />
					</svg>
					<span id="theme-text">Sunset</span>
				</button>
			</div>
		</nav>
	</header>

	<!-- Main Content Sections -->
	<main>
		<Hero />
		<About />
		<Experience />
		<Projects />
		<Contact />
	</main>
</Layout>

<script>
	// Theme toggle functionality
	const themeToggle = document.getElementById('theme-toggle');
	const themeText = document.getElementById('theme-text');

	function updateToggleButtonState() {
		const isDark = document.documentElement.classList.contains('dark-mode');
		if (themeText) {
			themeText.textContent = isDark ? 'Midnight' : 'Meadow';
		}
	}

	// Initial button text sync
	updateToggleButtonState();

	themeToggle?.addEventListener('click', () => {
		const root = document.documentElement;
		root.classList.toggle('dark-mode');
		
		const currentTheme = root.classList.contains('dark-mode') ? 'dark' : 'light';
		localStorage.setItem('theme', currentTheme);
		updateToggleButtonState();
	});

	// Discord copy functionality
	const discordNavBtn = document.getElementById('discord-nav-btn');
	const discordTooltip = document.getElementById('discord-nav-tooltip');

	discordNavBtn?.addEventListener('click', () => {
		const copyValue = discordNavBtn.getAttribute('data-copy-value') || '';
		navigator.clipboard.writeText(copyValue).then(() => {
			if (discordTooltip) {
				const originalText = discordTooltip.textContent;
				discordTooltip.textContent = 'Copied!';
				discordTooltip.classList.add('copied');
				
				setTimeout(() => {
					discordTooltip.textContent = originalText;
					discordTooltip.classList.remove('copied');
				}, 2000);
			}
		}).catch(err => {
			console.error('Failed to copy: ', err);
		});
	});
</script>
