---
import GhibliSky from './GhibliSky.astro';
---

<section id="home" class="hero-section">
  <!-- Sky background inside Hero -->
  <GhibliSky />

  <!-- Animated grass hills silhouettes at the bottom of hero -->
  <div class="hills">
    <div class="hill hill-1"></div>
    <div class="hill hill-2"></div>
  </div>

  <div class="container hero-content">
    <div class="intro-badge">🍃 Welcome to my digital clearing</div>
    <h1 class="hero-title">
      Hello, I'm <span class="highlight">Sangeeth Kumar</span>
    </h1>
    <p class="hero-subtitle">
      A Software Engineer dedicated to crafting simple, reliable automation, computer vision integrations, and elegant web platforms. Inspired by the calm and wonder of nature.
    </p>
    <div class="hero-actions">
      <a href="#projects" class="btn">View My Projects</a>
      <a href="#experience" class="btn btn-secondary">My Experience</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding-top: 80px;
    padding-bottom: 0;
    overflow: hidden;
    background: transparent;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 800px;
    margin-bottom: 8rem; /* Space for hills */
    animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .intro-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--card-border);
    backdrop-filter: blur(5px);
    border-radius: var(--radius-pill);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: 3.5rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: var(--space-3);
    color: var(--text-main);
  }

  .hero-title .highlight {
    background: linear-gradient(120deg, var(--accent-color) 0%, #d86856 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    position: relative;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: var(--text-muted);
    margin-bottom: var(--space-5);
    line-height: 1.8;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
  }

  /* Soft Nature Hills */
  .hills {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 160px;
    pointer-events: none;
    z-index: 2;
  }

  .hill {
    position: absolute;
    bottom: -10px;
    width: 150%;
    height: 220px;
    border-radius: 50%;
    transition: background 0.3s;
  }

  .hill-1 {
    left: -20%;
    background: var(--hill-color-1);
    opacity: 0.85;
    transform: rotate(-3deg);
  }

  .hill-2 {
    right: -25%;
    background: var(--hill-color-2);
    height: 180px;
    transform: rotate(2deg);
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 2.5rem;
    }
    .hero-subtitle {
      font-size: 1rem;
    }
    .hero-actions {
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }
    .hero-actions .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
    .hills {
      height: 100px;
    }
    .hill-1 {
      height: 140px;
    }
    .hill-2 {
      height: 120px;
    }
  }
</style>
