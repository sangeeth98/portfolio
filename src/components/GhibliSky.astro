---
// GhibliSky.astro: Drifting clouds and gentle floating leaves
---
<div class="interactive-sky">
  <!-- Drifting Clouds -->
  <div class="cloud cloud-type-1" style="top: 15%; animation-duration: 90s; animation-delay: -10s;"></div>
  <div class="cloud cloud-type-2" style="top: 35%; animation-duration: 140s; animation-delay: -45s;"></div>
  <div class="cloud cloud-type-1" style="top: 55%; animation-duration: 110s; animation-delay: -20s;"></div>
  <div class="cloud cloud-type-2" style="top: 75%; animation-duration: 180s; animation-delay: -80s;"></div>
  <div class="cloud cloud-type-1" style="top: 5%; animation-duration: 75s; animation-delay: -5s;"></div>

  <!-- Floating Leaves / Petals -->
  <div class="leaf green" style="left: 10%; animation-duration: 12s; animation-delay: 0s;"></div>
  <div class="leaf gold" style="left: 25%; animation-duration: 16s; animation-delay: -3s;"></div>
  <div class="leaf green" style="left: 45%; animation-duration: 14s; animation-delay: -7s;"></div>
  <div class="leaf gold" style="left: 60%; animation-duration: 20s; animation-delay: -2s;"></div>
  <div class="leaf green" style="left: 75%; animation-duration: 15s; animation-delay: -11s;"></div>
  <div class="leaf gold" style="left: 90%; animation-duration: 18s; animation-delay: -5s;"></div>
</div>

<style>
  /* Local styling tweaks if needed */
  .interactive-sky {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }
</style>
